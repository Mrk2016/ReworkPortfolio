---
// src/components/Projects.astro

//ecommerce
import PhpIcon from "../../components/icons/PhpIcon.astro";
import WooIcon from "../../components/icons/WooIcon.astro";
import BootstrapIcon from "../../components/icons/BootstrapIcon.astro";
import WordpressIcon from "../../components/icons/WordpressIcon.astro";
import MoodleIcon from "../../components/icons/MoodleIcon.astro";

//analytics
import AcfIcon from "../../components/icons/AcfIcon.astro";
import DiviIcon from "../../components/icons/DiviIcon.astro";
import MysqlIcon from "../../components/icons/MysqlIcon.astro";
import GithubIcon from "../../components/icons/GithubIcon.astro";
import JavascriptIcon from "../../components/icons/JavascriptIcon.astro";
import RedisIcon from "../../components/icons/RedisIcon.astro";
import TypescriptIcon from "../../components/icons/TypescriptIcon.astro";
import ExpressIcon from "../../components/icons/ExpressIcon.astro";
import DockerIcon from "../../components/icons/DockerIcon.astro";
import AwsIcon from "../../components/icons/AwsIcon.astro";

// Stack IA
import OllamaIcon from "../../components/icons/OllamaIcon.astro";

const projects = [
    {
        title: "E-commerce - Universidad Fidélitas",
        description: "Integración completa de comercio electrónico con sistema académico, panel de administración, carrito de compras, pasarela de pagos y gestión de inventario automático.",
        categories: ["E-commerce", "Plugins", "Web"],
        primaryCategory: "E-commerce",
        status: "Completado",
        duration: "5 meses",
        featured: true,
        placeholderBg: "linear-gradient(135deg, #0a0f1a 0%, #0d1220 50%, #080d18 100%)",
        placeholderGlow: "rgba(100, 116, 139, 0.12)",
        placeholderTechs: [
            { name: "WordPress", component: WordpressIcon },
            { name: "WooCommerce", component: WooIcon },
        ],
        technologies: [
            { name: "WordPress", component: WordpressIcon },
            { name: "Woo", component: WooIcon },
            { name: "Bootstrap", component: BootstrapIcon },
            { name: "Php", component: PhpIcon },
        ],
        demoUrl: "/projects/ecommerce",
        githubUrl: "#"
    },
    {
        title: "Serendipity Adventure",
        description: "Rediseño de un sitio web para empresa de viajes turísticos, con una interfaz de usuario moderna y una experiencia de usuario atractiva.",
        categories: ["Web"],
        primaryCategory: "Web",
        status: "Completado",
        duration: "2 meses",
        featured: false,
        placeholderBg: "linear-gradient(135deg, #001a14 0%, #001f18 50%, #00120e 100%)",
        placeholderGlow: "rgba(6, 182, 212, 0.12)",
        placeholderTechs: [
            { name: "WordPress", component: WordpressIcon },
            { name: "Divi", component: DiviIcon },
        ],
        technologies: [
            { name: "WordPress", component: WordpressIcon },
            { name: "ACF", component: AcfIcon },
            { name: "Divi", component: DiviIcon },
            { name: "PHP", component: PhpIcon }
        ],
        demoUrl: "/projects/serendipity",
        githubUrl: "#"
    },
    {
        title: "QR Code Generator - Universidad Fidélitas",
        description: "Plugin para wordpress que genera, lee y valida códigos QR para la feria vocacional de la Universidad Fidélitas.",
        categories: ["Web", "Plugins"],
        primaryCategory: "Plugins",
        status: "Completado",
        duration: "3 semanas",
        featured: true,
        placeholderBg: "linear-gradient(135deg, #00081a 0%, #000d1f 50%, #00061a 100%)",
        placeholderGlow: "rgba(59, 130, 246, 0.12)",
        placeholderTechs: [
            { name: "WordPress", component: WordpressIcon },
            { name: "PHP", component: JavascriptIcon },
        ],
        technologies: [
            { name: "wordpress", component: WordpressIcon },
            { name: "Mysql", component: MysqlIcon },
            { name: "GitHub", component: GithubIcon },
            { name: "PHP", component: PhpIcon }
        ],
        demoUrl: "/projects/qrscanner",
        githubUrl: "#"
    },
    {
        title: "FideBot Tutor IA",
        description: "Plugin de actividad para Moodle 5.0 que integra modelos locales de IA mediante Ollama. Permite configurar conexiones por token y definir el modelo de IA por actividad. Los estudiantes interactúan con un chat personalizado que resuelve dudas contextuales del curso.",
        categories: ["Stack IA", "Plugins"],
        primaryCategory: "Stack IA",
        status: "Completado",
        duration: "2 semanas",
        featured: true,
        placeholderBg: "linear-gradient(135deg, #0f0018 0%, #130020 50%, #0a0015 100%)",
        placeholderGlow: "rgba(168, 85, 247, 0.12)",
        placeholderTechs: [
            { name: "Ollama", component: OllamaIcon },
            { name: "Moodle", component: MoodleIcon },
        ],
        technologies: [
            { name: "Ollama", component: OllamaIcon },
            { name: "PHP", component: PhpIcon },
            { name: "Moodle", component: MoodleIcon },
        ],
        demoUrl: "/projects/fidebot-tutor-ia",
        githubUrl: "#"
    }
];
---

<section id="projects" class="px-[5%] py-20 max-w-7xl mx-auto">
    <!-- Header Section -->
    <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 bg-green-500/10 text-green-500 px-4 py-2 rounded-full text-sm font-medium mb-6 border border-green-500/20">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            Casos de Estudio
        </div>
        <h2 class="text-5xl font-bold mb-6 text-gradient">
            Proyectos Destacados
        </h2>
        <p class="text-xl text-gray-400 max-w-3xl mx-auto leading-relaxed">
            Selección de proyectos que demuestran mi experiencia en desarrollo full-stack, 
            desde aplicaciones web complejas hasta soluciones empresariales escalables.
        </p>
    </div>

    <!-- Filter Options -->
    <div class="flex justify-center mb-12">
        <div class="flex flex-wrap gap-3 bg-gray-800/30 p-2 rounded-2xl border border-white/10">
            <button class="filter-btn active px-6 py-2 rounded-xl text-sm font-medium transition-all duration-300" data-filter="all">
                Todos los proyectos
            </button>
            <button class="filter-btn px-6 py-2 rounded-xl text-sm font-medium transition-all duration-300" data-filter="featured">
                Destacados
            </button>
            <button class="filter-btn px-6 py-2 rounded-xl text-sm font-medium transition-all duration-300" data-filter="E-commerce">
                E-commerce
            </button>
            <button class="filter-btn px-6 py-2 rounded-xl text-sm font-medium transition-all duration-300" data-filter="Plugins">
                Plugins
            </button>
            <button class="filter-btn px-6 py-2 rounded-xl text-sm font-medium transition-all duration-300" data-filter="Web">
                Desarrollo Web
            </button>
            <button class="filter-btn px-6 py-2 rounded-xl text-sm font-medium transition-all duration-300" data-filter="Stack IA">
                Stack IA
            </button>
        </div>
    </div>
    
    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 projects-container">
        {projects.map((project, index) => (
            <div class={`project-card glass rounded-3xl overflow-hidden border border-white/10 project-item ${project.featured ? 'featured' : ''}`} 
                 data-categories={JSON.stringify(project.categories)}
                 data-featured={project.featured}
                 style={`animation-delay: ${index * 0.2}s`}>
                
                <!-- Project Header -->
                <div class="relative overflow-hidden">
                    <!-- Project Tech Placeholder -->
                    <div class="w-full h-64 relative overflow-hidden flex items-center justify-center"
                         style={`background: ${project.placeholderBg}`}>
                        <!-- Decorative dots pattern -->
                        <div class="absolute inset-0 tech-dots-pattern opacity-20"></div>
                        <!-- Accent glow -->
                        <div class="absolute inset-0" style={`background: radial-gradient(ellipse at center, ${project.placeholderGlow} 0%, transparent 70%)`}></div>
                        <!-- Tech icons -->
                        <div class="relative z-10 flex gap-6 justify-center items-center px-8">
                            {project.placeholderTechs.map((tech, i) => (
                                <>
                                    <div class="flex flex-col items-center gap-3 group/icon">
                                        <div class="w-20 h-20 rounded-2xl flex items-center justify-center border border-white/10 backdrop-blur-sm transition-transform duration-300 group-hover/icon:scale-110 tech-icon-card"
                                             style={`background: rgba(255,255,255,0.04)`}>
                                            <tech.component class="w-11 h-11" />
                                        </div>
                                        <span class="text-sm text-gray-300 font-medium">{tech.name}</span>
                                    </div>
                                    {i < project.placeholderTechs.length - 1 && (
                                        <span class="text-2xl font-light text-gray-500 mb-6 select-none">+</span>
                                    )}
                                </>
                            ))}
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                        
                        <!-- Status Badge -->
                        <div class="absolute top-4 right-4">
                            <span class={`px-3 py-1 rounded-full text-xs font-bold border backdrop-blur-sm ${
                                project.status === 'Completado' 
                                    ? 'bg-green-500/90 text-white border-green-500/30 shadow-lg' 
                                    : 'bg-yellow-500/90 text-white border-yellow-500/30 shadow-lg'
                            }`}>
                                {project.status}
                            </span>
                        </div>
                        
                        <!-- Featured Badge -->
                        {project.featured && (
                            <div class="absolute top-4 left-4">
                                <span class="bg-gradient-to-r from-green-600 to-green-500 text-white px-3 py-1 rounded-full text-xs font-medium flex items-center gap-1 shadow-lg backdrop-blur-sm">
                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                    </svg>
                                    Destacado
                                </span>
                            </div>
                        )}

                        <!-- Category Badge (dinámico por primaryCategory) -->
                        <div class="absolute bottom-4 left-4">
                            {project.primaryCategory === 'Stack IA' && (
                                <span class="bg-gradient-to-r from-purple-700 to-purple-500 text-white px-3 py-1 rounded-full text-xs font-medium flex items-center gap-1 shadow-lg backdrop-blur-sm">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                                    </svg>
                                    Stack IA
                                </span>
                            )}
                            {project.primaryCategory === 'E-commerce' && (
                                <span class="bg-gradient-to-r from-orange-600 to-orange-400 text-white px-3 py-1 rounded-full text-xs font-medium flex items-center gap-1 shadow-lg backdrop-blur-sm">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                    </svg>
                                    E-commerce
                                </span>
                            )}
                            {project.primaryCategory === 'Plugins' && (
                                <span class="bg-gradient-to-r from-blue-700 to-blue-500 text-white px-3 py-1 rounded-full text-xs font-medium flex items-center gap-1 shadow-lg backdrop-blur-sm">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path>
                                    </svg>
                                    Plugin
                                </span>
                            )}
                            {project.primaryCategory === 'Web' && (
                                <span class="bg-gradient-to-r from-cyan-600 to-cyan-400 text-white px-3 py-1 rounded-full text-xs font-medium flex items-center gap-1 shadow-lg backdrop-blur-sm">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                                    </svg>
                                    Web
                                </span>
                            )}
                        </div>
                    </div>
                </div>
                
                <!-- Project Content -->
                <div class="p-8">
                    <!-- Project Meta -->
                    <div class="flex items-center justify-between mb-4">
                        <!-- Categorías múltiples -->
                        <div class="flex flex-wrap gap-2">
                            <span class={`px-3 py-1 rounded-full text-xs font-medium border ${
                                project.primaryCategory === 'Stack IA'
                                    ? 'bg-purple-500/10 text-purple-400 border-purple-500/20'
                                    : 'bg-green-500/10 text-green-500 border-green-500/20'
                            }`}>
                                {project.primaryCategory}
                            </span>
                            {project.categories.filter(cat => cat !== project.primaryCategory).map((category) => (
                                <span class="bg-blue-500/10 text-blue-400 px-3 py-1 rounded-full text-xs font-medium border border-blue-500/20">
                                    {category}
                                </span>
                            ))}
                        </div>
                        <span class="text-gray-400 text-sm flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            {project.duration}
                        </span>
                    </div>
                    
                    <h3 class="text-white text-2xl font-bold mb-3 group-hover:text-green-400 transition-colors duration-300">
                        {project.title}
                    </h3>
                    
                    <p class="text-gray-300 mb-6 leading-relaxed">
                        {project.description}
                    </p>
                    
                    <!-- Technologies -->
                    <div class="flex flex-wrap gap-3 mb-8">
                        {project.technologies.map((tech) => (
                            <div class="tech-badge flex items-center gap-2 bg-green-500/10 text-green-400 px-4 py-2 rounded-full text-sm border border-green-500/20 hover:bg-green-500/20 transition-all duration-300 group/tech">
                                <tech.component class="w-4 h-4 group-hover/tech:scale-110 transition-transform duration-300 tech-icon" />
                                <span class="font-medium">{tech.name}</span>
                            </div>
                        ))}
                    </div>
                    
                    <!-- Project Links -->
                    <div class="flex gap-4">
                        <a 
                            href={project.demoUrl} 
                            class="flex items-center gap-2 bg-gradient-to-r from-green-600 to-green-500 text-white px-6 py-3 rounded-xl font-semibold hover:shadow-lg hover:shadow-green-500/25 transition-all duration-300 hover:-translate-y-1 group"
                        >
                            <svg class="w-5 h-5 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                            </svg>
                            Conocer más
                        </a>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
        const projectItems = document.querySelectorAll<HTMLElement>('.project-item');
        
        filterButtons.forEach(button => {
            button.addEventListener('click', () => {
                const filter = button.getAttribute('data-filter');
                
                if (!filter) return;
                
                filterButtons.forEach(btn => btn.classList.remove('active'));
                button.classList.add('active');
                
                projectItems.forEach((item, index) => {
                    if (item instanceof HTMLElement) {
                        const categoriesData = item.getAttribute('data-categories');
                        const featured = item.getAttribute('data-featured') === 'true';
                        
                        let shouldShow = false;
                        
                        if (filter === 'all') {
                            shouldShow = true;
                        } else if (filter === 'featured') {
                            shouldShow = featured;
                        } else if (categoriesData) {
                            try {
                                const categories: string[] = JSON.parse(categoriesData);
                                shouldShow = categories.includes(filter);
                            } catch (e) {
                                console.error('Error parsing categories:', e);
                                shouldShow = false;
                            }
                        }
                        
                        if (shouldShow) {
                            item.style.display = 'block';
                            setTimeout(() => {
                                item.style.opacity = '1';
                                item.style.transform = 'translateY(0)';
                            }, index * 100);
                        } else {
                            item.style.opacity = '0';
                            item.style.transform = 'translateY(20px)';
                            setTimeout(() => {
                                item.style.display = 'none';
                            }, 300);
                        }
                    }
                });
            });
        });
    });
</script>

<style>
    /* Tech Placeholder */
    .tech-dots-pattern {
        background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px);
        background-size: 24px 24px;
    }

    .tech-icon-card {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    }

    /* Animaciones de entrada */
    .project-card {
        opacity: 0;
        transform: translateY(30px);
        animation: slideInUp 0.6s ease-out forwards;
        transition: all 0.3s ease;
    }
    
    @keyframes slideInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Efectos hover mejorados */
    .project-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px rgba(34, 197, 94, 0.3);
        border-color: rgba(34, 197, 94, 0.3);
    }

    .project-card:hover img {
        transform: scale(1.05);
    }
    
    /* Filtros */
    .filter-btn {
        color: #9ca3af;
        background: transparent;
        border: none;
        cursor: pointer;
    }
    
    .filter-btn:hover,
    .filter-btn.active {
        color: #22c55e;
        background: rgba(34, 197, 94, 0.1);
    }

    /* Stack IA filter button activo en morado */
    .filter-btn[data-filter="Stack IA"].active,
    .filter-btn[data-filter="Stack IA"]:hover {
        color: #a855f7;
        background: rgba(168, 85, 247, 0.1);
    }
    
    /* Categorías secundarias en azul */
    .bg-blue-500\/10 {
        background: rgba(59, 130, 246, 0.1);
    }
    
    .text-blue-400 {
        color: #60a5fa;
    }
    
    .border-blue-500\/20 {
        border-color: rgba(59, 130, 246, 0.2);
    }

    /* Stack IA badge morado */
    .bg-purple-500\/10 {
        background: rgba(168, 85, 247, 0.1);
    }
    
    .text-purple-400 {
        color: #c084fc;
    }
    
    .border-purple-500\/20 {
        border-color: rgba(168, 85, 247, 0.2);
    }
    
    /* Tech badges */
    .tech-badge {
        backdrop-filter: blur(8px);
        box-shadow: 0 2px 8px rgba(34, 197, 94, 0.1);
    }
    
    .tech-badge:hover {
        box-shadow: 0 4px 12px rgba(34, 197, 94, 0.2);
        transform: translateY(-1px);
    }
    
    .tech-icon {
        filter: brightness(1.2) contrast(1.1);
        opacity: 0.9;
    }
    
    .tech-badge:hover .tech-icon {
        filter: brightness(1.4) contrast(1.2);
        opacity: 1;
    }
    
    /* Modo claro */
    html.light .project-card {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    }

    html.light .project-card:hover {
        background: rgba(255, 255, 255, 0.95);
        border-color: rgba(34, 197, 94, 0.3);
        box-shadow: 0 15px 40px rgba(34, 197, 94, 0.15);
    }
    
    html.light .text-white {
        color: #1f2937 !important;
    }
    
    html.light .text-gray-300 {
        color: #4b5563 !important;
    }
    
    html.light .text-gray-400 {
        color: #6b7280 !important;
    }
    
    html.light .bg-gray-800\/30 {
        background: rgba(255, 255, 255, 0.9) !important;
        border: 1px solid rgba(148, 163, 184, 0.2) !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }
    
    html.light .tech-badge {
        background: rgba(34, 197, 94, 0.15) !important;
        border-color: rgba(34, 197, 94, 0.3) !important;
        color: #059669 !important;
        backdrop-filter: blur(12px);
        box-shadow: 0 2px 8px rgba(34, 197, 94, 0.15);
    }
    
    html.light .tech-badge:hover {
        background: rgba(34, 197, 94, 0.25) !important;
        border-color: rgba(34, 197, 94, 0.4) !important;
        box-shadow: 0 4px 12px rgba(34, 197, 94, 0.25);
        transform: translateY(-2px);
    }
    
    html.light .tech-icon {
        filter: brightness(0.8) contrast(1.3) saturate(1.2);
        opacity: 1;
    }
    
    html.light .tech-badge:hover .tech-icon {
        filter: brightness(0.7) contrast(1.4) saturate(1.3);
        opacity: 1;
    }
    
    html.light .bg-blue-500\/10 {
        background: rgba(59, 130, 246, 0.15) !important;
        border-color: rgba(59, 130, 246, 0.3) !important;
    }
    
    html.light .text-blue-400 {
        color: #2563eb !important;
    }
    
    html.light .border-blue-500\/20 {
        border-color: rgba(59, 130, 246, 0.3) !important;
    }

    html.light .bg-purple-500\/10 {
        background: rgba(168, 85, 247, 0.15) !important;
        border-color: rgba(168, 85, 247, 0.3) !important;
    }

    html.light .text-purple-400 {
        color: #7c3aed !important;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .project-card {
